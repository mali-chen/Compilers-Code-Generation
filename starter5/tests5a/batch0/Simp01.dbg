########################################################
# vm_init (millicode)
#  - initialzes the virtual machine
#  - values 5 stored in $s5
#  - zero ("this pointer") stored in $s2
#  - heap and heap-limit pointers stored respectively in $s3 and $s4
#  - address of bottom of stack stored in 'stack_bottom' memory
#    location
#  - (note: 'cur_seg' memory location is already set to 0)
########################################################
2924:vm_init:

    # mark bottom of stack
2924#    sw $sp,stack_bottom
    
    # set "this" pointer to be null, for now
2928#    move $s2,$zero

    #set up the "five" register
2932#    li $s5,5

2936#    la $s3,seg0_start
2940#    la $s4,seg0_end
2941##...lui $s4,16
2945##...addiu $s4,$s4,3732
    
    # return
2948#    jr $ra

########################################################
# divide (millicode)
#  - divides first arg by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2952:divide:
    # get parameters; abort if divisor zero
2952#    lw $t0,($sp)
2956#    lw $t1,8($sp)
2960#    beq $t0,$zero,divByZeroError
    
    # perform division
2964#    div $t1,$t0
2968#    mflo $t0

    # store result, adjust stack and return
2972#    addu $sp,$sp,8 # adjust stack
2976#    sw $t0,($sp) # store result
2980#    jr $ra

########################################################
# remainder (millicode)
#  - takes remainder first arg divided by second (signed divide)
#  - aborts if divisor is zero
#  - follows calling conventions for library methods
#  - parameters:
#    - ($sp) divisor
#    - 4($sp) (dummy) GC tag
#    - 8($sp) dividend
#    - 12($sp) (dummy) GC tag
#  - return value:
#    - ($sp) result
#    - 4($sp) (dummy) GC tag
########################################################
2984:remainder:
    # get parameters; abort if divisor zero
2984#    lw $t0,($sp)
2988#    lw $t1,8($sp)
2992#    beq $t0,$zero,divByZeroError
    
    # perform division
2996#    div $t1,$t0
3000#    mfhi $t0

    # store result, adjust stack and return
3004#    addu $sp,$sp,8 # adjust stack
3008#    sw $t0,($sp) # store result
3012#    jr $ra
    
########################################################
# checkCast (millicode) - checks that a cast is legal
#  - aborts if null
#  - aborts if cast is illegal cast
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) object to check (now checked)
#  - side-effects: clobbers $t2 and $t3
########################################################
3016:checkCast:
    # get object, allow immediately if null
3016#    lw $t2,($sp)
3020#    beq $t2,$zero,checkCastReturn
    
    # get vtable address of object, abort if less than
    # lower limit or greater then or equal to higher
    # limit
3024#    lw $t2,-12($t2) # vtable address
3028#    bge $t2,$t1,castException
3029##...slt $at,$t2,$t1
3033##...beq $at,$zero,3204
3036#    blt $t2,$t0,castException
3037##...slt $at,$t2,$t0
3041##...bne $at,$zero,3204
    
    # return, leaving object unchanged on stack
3044:  checkCastReturn:    
3044#    jr $ra    
