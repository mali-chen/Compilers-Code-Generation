844#    subu $t0,$v0,10
848#    beq $t0,$zero,riSkipWhiteLoop # start over if newline
852#    subu $t0,$v0,9
856#    beq $t0,$zero,riSkipWhiteLoop # start over if tab
860#    subu $t0,$v0,13
864#    beq $t0,$zero,riSkipWhiteLoop # start over if carriage return
868#    subu $t0,$v0,12
872#    beq $t0,$zero,riSkipWhiteLoop # start over if form-feed
876#    j badIntegerFormat # illegal integer char: abort program

880:  nonWhite:
