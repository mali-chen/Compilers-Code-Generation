4#  li $s6, 1
8#  li $s7, 0
12# jal newObject
16#  la $t0, CLASS_Main
20#  sw $t0, -12($s7)
24#  addu $sp,$sp,4
28#  move $s2, $s7
32#  jal mth_main_Main
36#  li $v0, 10
40#  syscall
44:mth_main_Main:
44# subu $sp, $sp, 4 # MethodDeclVoid at 2.15; stackHeight = 0
48# sw $ra, 0($sp) # MethodDeclVoid at 2.15; stackHeight = 0
52# move $fp, $sp # MethodDeclVoid at 2.15; stackHeight = 0
