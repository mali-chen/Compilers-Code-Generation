########################################################
# instanceOf (millicode) - tests whether an object is
#   a member of a given class (or subclass)
#  - returns false if object is null
#  - parameters:
#    - ($sp) object to check
#    - $t0 address of vtable for target-class
#    - $t1 address one past vtable address of last
#      subclass of target-class
#  - return value:
#    - ($sp) true (1) or false (0), depending on whether
#      object is a member
#  - side-effects: clobbers $t2 and $t3
########################################################
3048:instanceOf:
    # get object, go return false if null
3048#    lw $t2,($sp)
3052#    beq $t2,$zero,doneInstanceOf
    
    # get vtable address of object, determine if we're >= the
    # lower limit, and if we're < the higher limit
3056#    lw $t2,-12($t2) # vtable address
3060#    sge $t0,$t2,$t0 # are we >= the lower limit?
3061##...slt $t0,$t2,$t0
3065##...xori $t0,$t0,0x1
3068#    slt $t1,$t2,$t1 # are we < the higher limit?
    
    # store the AND of the two conditions onto the stack; return
3072#    and $t2,$t0,$t1
3076#    sw $t2,($sp)
3080:doneInstanceOf: # if we reach here via branch, stack-top is zero,
            # which will now represent false
3080#    jr $ra


###########################################################
# jump-targets to terminate program:
# - exit: returns normally
# - outOfHeapMemory: prints "out of memory" error and returns
###########################################################

3084:exitError:
    # assumes $a0 has pointer to null-terminated string

    # print the string
3084#    li $v0,4 # syscall-code for print-string
3088#    syscall
3092:exit:
    # print termination message
3092#    li $v0,4 # syscall-code for print-string
3096#    la $a0,exitString
3100#    syscall

    # print number of garbage collections
3104#    li $v0,4 # syscall-code for print-string
3108#    la $a0,gcCountMsg
3112#    syscall # print "Number of ..."
3116#    lw $a0,gcCount # number of GC's
3120#    li $v0,1 # code for print-int
3124#    syscall
3128#    li $v0,4 # syscall-code for print-string
3132#    la $a0,newlineString
3136#    syscall # print newline

    # terminate execution
3140#    li $v0,10 #syscall-code for "exit"
3144#    syscall

3148:outOfHeapMemory:
3148#    la $a0,heapMemoryMsg
3152#    j exitError
3156:divByZeroError:
3156#    la $a0,divByZeroMsg
3160#    j exitError
3164:strIndexOutOfBounds:
3164#    la $a0,strIndexOutOfBoundsMsg
3168#    j exitError
3172:arrayIndexOutOfBounds:
3172#    la $a0,arrayIndexOutOfBoundsMsg
3176#    j exitError
3180:arraySizeOutOfBounds:
3180#    la $a0,arraySizeOutOfBoundsMsg
3184#    j exitError
3188:nullPtrException:
3188#    la $a0,nullPtrExceptionMsg
3192#    j exitError
3196:badIntegerFormat:
3196#    la $a0,badIntegerFormatMsg
3200#    j exitError
3204:castException:
3204#    la $a0,castExceptionMsg
3208#    j exitError
############## data section ################
    .data
3360:hexChars:
    .ascii "0123456789abcdef"
    .align 2
3376:cur_seg:
    .word 0

3380:lastCharRead:
    .word -2 # -2 => no buffered character
3384:prevHashConstant:
    .word 0x2785173c
3388:gcCount:
    .word 0

3392:heapMemoryMsg:
    .asciiz "ERROR: out of heap memory\n"
3419:divByZeroMsg:
    .asciiz "ERROR: divide by zero\n"
3442:strIndexOutOfBoundsMsg:
    .asciiz "ERROR: string index out of bounds\n"
3477:arrayIndexOutOfBoundsMsg:
    .asciiz "ERROR: array index out of bounds\n"
3511:arraySizeOutOfBoundsMsg:
    .asciiz "ERROR: array size out of bounds\n"
3544:nullPtrExceptionMsg:
    .asciiz "ERROR: null-pointer exception\n"
3575:badIntegerFormatMsg:
    .asciiz "ERROR: attempt to read badly formatted integer\n"
3623:castExceptionMsg:
    .asciiz "ERROR: illegal cast\n"
3644:gcMsg: 
      .asciiz "\nGC!\n"
3650:gcCountMsg: 
      .asciiz "Number of garbage collections: "

3682:nullStr:
    .asciiz "null"
3687:trueString:
    .asciiz "true"
3692:falseString:
    .asciiz "false"
3698:exitString:
    .ascii "Program execution completed."
    #### "falls through" here
3726:newlineString:
    .asciiz "\n"
    
    .align 2
3728:stack_bottom:
    .word 0

