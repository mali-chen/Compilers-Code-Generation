##############################################################
# MiniJava/UP library for MIPS/Spim -- version that assumes
#    one-word boolean on stack
# author: Steven R. Vegdahl
# date: 7-13 July 2004
# modified 12-17 March 2007
# modified 3-25 May 2007
# modified 2 May 2015
# modified 7 March 2016
# modified 11 May - 31 June 2017
# modified 2024 Steven Libby changed calling conventions
#               This is now passed in s2, 
#               and methods don't pop parameters
# status: Seems to work on all test cases.
###############################################################




###############################################################
# hashCode() - library method (class Object)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer (for Object)
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
72:mth_hashCode_Object:
    # for now, we'll return the -8 offset word, shifted/added to
    # itself, then XORed with a fixed "random" value
72#    lw $t0,-8($s2) # get word with hash bits from this
76#    srl $t1,$t0,11 # shift/add to introduce more "randomness"
80#    addu $t0,$t1

84#    jr $ra # return, no change to the stack

###############################################################
# equals() - library method (class Object)
# - tests whether two objects are equal
# - produces boolean that tells whether two objects are equal--
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
88:mth_equals_Object:
88#    move $t0,$s2 # first pointer (this)
92#    lw $t1,($sp) # second pointer
96#    seq $t0,$t0,$t1 # produce boolean telling if they are equal
97##...subu $at,$t0,$t1
101##...sltiu $t0,$at,1

104#    jr $ra # return

###############################################################
# hashCode() - library method (class String)
# - returns a hash code for an object
# - produces int that is the object's hash code
#   meaning that they are the same physical object
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - 1 if the objects were the same; 0 otherwise
###############################################################
108:mth_hashCode_String:
108#    move $t0,$s2 # put this pointer in t0

112#    li $t2,0 # current hash value
116#    lw $t1,-4($t0) # negative of number of characters in string
120#    beq $t1,$zero,done_hashCode_String # if zero length => done
124#    addu $t0,$t1 # address of first character in string +12,
                 # not accounting for padding and header words
128#    and $t0,0xfffffffc # adjust for padding
129##...lui $at,65535
133##...ori $at,$at,0xfffc
137##...and $t0,$t0,$at
140#    subu $t1,$t0,$t1 # address at end of string +12
144:loop_hashCode_String:    
144#    sll $t4,$t2,5 # multiply by 32
148#    subu $t2,$t4,$t2 # subtract original, so that it's now multiply by 31
152#    lbu $t3,-12($t0) # current character
156#    addu $t2,$t3 # add in current character
160#    addu $t0,1 # go to next character's address
164#    bne $t0,$t1,loop_hashCode_String # loop back if more
168:done_hashCode_String:    

    # push int on stack
168#    move $t0, $t2 # put $t2 in return slot
172#    jr $ra # return

###############################################################
# toString() - library method (class Object)
# - returns a String version of the object
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
# ****NOTE: this method counts on the fact that the hashCode method
# ****is in slot 0 of the vtable    
###############################################################
176:mth_toString_Object:
    # we need to append:
    # - a string created from the object name in the negative portion of
    #   the vtable
    # - an at-sign "@"
    # - the hex version of the hashcode for the object, with no leading
    #   zeros

    # save return address. Get new this pointer
176#    subu $sp,4
180#    sw $ra,($sp)
    
    # get hash value
184#    lw $t2,-12($s2) # vtable address
188#    lw $t0,($t2) # method address
192#    jalr $t0
196#    subu $sp,8 # push result (int in $t0) on stack
200#    sw $s5,4($sp)
204#    sw $t0,($sp)

    # compute print-size of hash value
208#    li $t0, 1
212#    lw $t1, ($sp)
216#    srl $t1,$t1,4
220#    beq $t1,$zero,toString_skip_loop
224:toString_loop_top:
224#    addu $t0,1
228#    srl $t1,$t1,4
232#    bne $t1,$zero,toString_loop_top
236:toString_skip_loop:
236#    subu $sp,8
240#    sw $s5,4($sp)
244#    sw $t0,($sp)
    
    ################################################################
    # at this point, the stack looks like (from top):
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    ################################################################

    # determine the size of the "prefix string"
248#    lw $t2,-12($s2) # vtable address
252#    move $t0,$t2
256:toString_checkTagBit:
256#    subu $t0,1
260#    lb $t1,($t0)
264#    and $t1,0x80
265##...lui $at,0
269##...ori $at,$at,0x80
273##...and $t1,$t1,$at
276#    beq $t1,$zero,toString_checkTagBit
280#    subu $t1,$t2,$t0 # size of the prefix string, in bytes
284#    subu $sp,8
288#    sw $t1,($sp)
292#    sw $s5,4($sp) # push size onto stack

    # determine the header words for the string object's header
296#    move $s7,$zero # -4 offset header word
300#    lw $t4,8($sp) # bytes for hash value
304#    addu $t4,$t1 # bytes for prefix
    # add 8, to account for:
    #  - +1 for the '@' character
    #  - +4 for the vtable word
    #  - +3 to get the effect of rounding up rather than down
308#    addu $t4,8
312#    srl $s6,$t4,2 # divide by 4
    
    # allocate the object
316#    jal newObject
        
    ################################################################
    # at this point, the stack looks like (from top):
    # - new object, allocated to be our string
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $s7 also contains the address of the new object
    ################################################################

320#    li $t0,CLASS_String # store string vtable address into ...
324#    sw $t0,-12($s7) # ... -12 offset in object header
328#    lw $t2,-12($s2) # our object's vtable address
332#    lw $t5,4($sp) # number characters in prefix
336#    lw $t1,12($sp) # number of characters in hashcode
340#    addu $t3,$t1,$t5 # number of characters in string ...
344#    addu $t3,1 # ... including the '@' character
348#    subu $t0,$zero,$t3 # store negated length into ...
352#    sw $t0,-4($s7) # ... -4 offset header word
356#    lw $t0,-8($s7) # get -8 offset header-word
360#    bge $t0,$zero,skipMask_toString # don't strip hash code if not there
361##...slt $at,$t0,$zero
365##...beq $at,$zero,384
368#    and $t0,0xff # mask off object's hash value ...
369##...lui $at,0
373##...ori $at,$at,0xff
377##...and $t0,$t0,$at
380#    sw $t0,-8($s7) # ... and store back into -8 header-word
384:skipMask_toString:
384#    sll $t0,2 # convert to byte-offset (and shift off top bit, if there)
388#    subu $t0,$s7,$t0 # address first byte of string +8
#    addu $t1,$t0,$t3 # address of one past last byte of string +8
    
    # copy the prefix into the string
392#    subu $t4,$t2,$t5
396:toString_copyLoop:    
396#    lb $t3,($t4)
400#    and $t3,0x7f # mask off sign bit (in case first word)
401##...lui $at,0
405##...ori $at,$at,0x7f
409##...and $t3,$t3,$at
412#    sb $t3,-8($t0)
416#    addu $t4,1
420#    addu $t0,1
424#    blt $t4,$t2,toString_copyLoop
425##...slt $at,$t4,$t2
429##...bne $at,$zero,396

    # copy the '@' sign
432#    li $t3,'@'
436#    sb $t3,-8($t0)
                
    ################################################################
    # at this point, the stack looks like (from top):
    # - the new string object that we are building
    # - number of characters in the prefix
    # - GC tag (5)
    # - print-size (in bytes) of the hash value
    # - GC tag (5)
    # - hash value
    # - GC tag (5)
    # - return address
    # - old this pointer
    # - ... rest of stack
    # $t0 contains the address of next byte to store, +8
    # $t1 the number of characters in the hashcode
    # $s2 contains the object on which toString() has been called
    # $s7 also contains the address of the new object
    ################################################################

    # store the hex version of the hash value
440#    addu $t2,$t0,$t1 # address of last byte in string to store +8
444#    lw $t3,20($sp) # hash code to print
448:toString_hashCopyLoop:
448#    and $t4,$t3,0xf
452#    srl $t3,4
456#    lb $t4,hexChars($t4)
460#    sb $t4,-8($t2)
464#    subu $t2,$t2,1
468#    bgt $t2,$t0,toString_hashCopyLoop
469##...slt $at,$t0,$t2
473##...bne $at,$zero,448

    # blow away stack until return address
    # put return address in $ra, 
    # and put return string on top of stack
476#    addu $sp,28
480#    lw $ra,($sp)
484#    addu $sp,4
488#    move $t0, $s7 # return string we created
492#    jr $ra

###############################################################
# equals() - library method (class String)
# - the String version of the .equals method
# - produces false if the second object is null or is not a String ;
#   otherwise produces true iff the two strings have the same contents
# - parameters:
#   - $s2 - this-pointer
#   - ($sp) - object to compare to
#   - 4($sp) - old-this-pointer
# - return-value:
#   - ($sp) - 1 if the objects were the same; 0 otherwise
###############################################################
496:mth_equals_String:
    
    # quick test for obvious false
496#    lw $t0,($sp) # second parameter
500#    beq $t0,$zero,goEsFalse # go return false if null
504#    lw $t1,-12($t0) # vtable pointer
508#    la $t2,CLASS_String # string vtable pointer
512#    bne $t1,$t2,goEsFalse # go return false if not a string

    # save $ra, $s2, second parameter
    # we don't need to swap $s2, 
    # because it's still in the string class.
516#    subu $sp,12
520#    sw $ra,8($sp)
524#    sw $s2,4($sp)
528#    sw $t0,($sp)
532#    jal mth_compareTo_String
536#    lw $s2, 4($sp) #restore this pointer and pop parameters
540#    addu $sp, 8 # pop parameters

    # return value is 1 iff result is 0; else 0
544#    seq $t0,$t0,$zero
545##...subu $at,$t0,$zero
549##...sltiu $t0,$at,1

    # pop return address and return $t0
552#    lw $ra,($sp)
556#    addu $sp,4

560#    jr $ra # return
    
564:goEsFalse:
    # put 0 in $t0 and return
564#    li $t0, 0
568#    jr $ra # return

###############################################################
# toString() - library method (class String)
# - returns a String version of the object
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - the string version of the object
###############################################################
572:mth_toString_String:
    #we are a string, so return this.
572#    move $t0, $s2
576#    jr $ra

###############################################################
# readLine() - library method (class Lib)
# - reads line from standard input
# - produces String that contains the line read, except that it
#   does not include the end-of-line character-sequence. An
#   end-of-line character-sequence is one of the following:
#   - a return character followed by a newline character
#   - a newline character not preceded by a return character
#   - a return character not followed by a newline character
#   - an end-of-file character that follows at least one data
#     character
# - returns null on end-of-file
# - parameter:
#   - $s2 - this-pointer
#   - ($sp) - old-this-pointer
# - return-value:
#   - $t0 - pointer to string containing line that was read
# - anomalies:
#   - with bare "return", looks ahead one character to check for
#     newline.  This could cause non-intuitive behavior when
#     run interactively.
###############################################################
580:mth_readLine_Lib:
    
580#    subu $sp,$sp,8 # allocate space for data tag, saving $ra
584#    sw $ra, 4($sp) # save $ra
588#    move $t1,$sp # save "original" sp

592:  doRead:

    # read the character
592#    jal readLogicalChar

    # if we have a 'return', read another character to check for
    # newline
596#    subu $t2,$v0,13
600#    bne $t2,$zero,notReturnRL
604#    jal readLogicalChar
608#    subu $t2,$v0,10 # check for newline
612#    beq $t2,$zero,foundNewLine
616#    sw $v0,lastCharRead # push back character into queue
620#    j foundNewLine # go process the line

624:  notReturnRL:

    # at this point, $v0 has our character

624#    subu $t0,$v0,10
628#    beq $t0,$zero,foundNewLine
632#    blt $v0,$zero,foundEof
633##...slt $at,$v0,$zero
637##...bne $at,$zero,652

    # we have a character, so push it onto stack
640#    subu $sp,$sp,4
644#    sw $v0,($sp)

    # loop back up to get next character
648#    j doRead

652:  foundEof:
    # if we had actually read some characters before hitting
        # the eof, go return them as if a newline had been read
652#    bne $t1,$sp foundNewLine

    # otherwise, we got end of file without having read any
    # new characters, so return null
656#    li $s7, 0 # return-value: null
660#    j rlReturn # return

664:  foundNewLine:

    # at this point, we have our newline (or end-of-file), and all space
    # on the stack above $t1 are characters to be put into the string.
    # That is therefore the number of data words to allocate (plus 1
    # more for the class-pointer)


    # set up GC tag and char-count on stack
664#    subu $t0,$t1,$sp # number of chars we read (times 4)
668#    srl $s6,$t0,2 # number of words on stack with chars
672#    subu $sp,$sp,4 # push char-count ...
676#    sw $s6,($sp) # ... onto stack
680#    addu $t2,$t0,5 # GC tag, incl. for count-word
684#    sw $t2,($t1) # store GC tag
    
    # allocate the appropriate Object
688#    addu $s6,$s6,7 # 3 to round up, plus 1 for v-table pointer word
692#    srl $s6,$s6,2  # data words in object
696#    move $s7,$zero # object words in object
700#    jal newObject  # allocate space
    
    # store header words
704#    la $t0,CLASS_String
